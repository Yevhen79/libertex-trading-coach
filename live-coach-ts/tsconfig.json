{
  "compilerOptions": {
    "target": "ES2019",
    "module": "none",
    "lib": ["DOM", "DOM.Iterable", "ES2019"],
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "newLine": "lf",
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"]
}
